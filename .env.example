# Public site configuration. Copy to `.env` and fill these in before launch.
# VITE_* vars are exposed to the browser; everything else stays server-side.
# All have development-friendly fallbacks so the site renders if unset.

# "Add to Chrome" CTA on the home page.
VITE_CHROME_STORE_URL=

# Repository link used in nav, footer, and the GitHub CTAs.
VITE_GITHUB_URL=https://github.com/jpreecedev/mend-a11y

# Issues URL for the Support page. Defaults to `${GITHUB_URL}/issues` if unset.
VITE_GITHUB_ISSUES_URL=

# Contact address. If left blank, contact links fall back to GitHub issues.
VITE_CONTACT_EMAIL=

# Effective date shown on the Privacy page (e.g. "1 June 2026").
VITE_PRIVACY_EFFECTIVE_DATE=

# --- Database (Postgres) ---
# Optional. When unset, the app uses PGlite — an embedded Postgres persisted
# to ./.data/pglite — so the whole stack runs locally with zero services.
# Set a connection string to use a real Postgres server instead.
# Either way, run `pnpm db:push` once to create the tables.
DATABASE_URL=

# --- Better Auth ---
# Generate a strong secret, e.g. `openssl rand -base64 32`.
BETTER_AUTH_SECRET=
# Base URL of the app, no trailing slash.
BETTER_AUTH_URL=http://localhost:3000

# --- Optional sign-in methods (off by default) ---
# Google: set both server credentials AND the public flag to show the button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_AUTH_GOOGLE=false
# Magic link: needs a real email sender in production. The dev fallback logs
# the link to the server console. Set the public flag to show the button.
VITE_AUTH_MAGIC_LINK=false
